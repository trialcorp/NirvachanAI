# =====================================================
# Election Saathi India — Environment Variables
# =====================================================
# Copy this file to .env and fill in your real keys.
# NEVER commit the actual .env file to version control.
# =====================================================

# --- Google Gemini AI (Required) ---
# Powers the Election Coach conversational assistant
# Get your key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-1.5-flash

# --- Google Cloud Project ---
VITE_GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# --- Google Maps (Optional) ---
# Powers the Polling Booth Locator feature
# Get your key: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Google Cloud Translation (Optional) ---
# Powers the multi-language translation widget
# Enable at: https://console.cloud.google.com/apis/library/translate.googleapis.com
VITE_GOOGLE_TRANSLATION_API_KEY=your_translation_api_key_here

# --- Application ---
VITE_APP_ENV=development
